"""
bootstrap_ci.py — WildGuard AI
Bootstrap confidence intervals for model accuracy.
Add to backend/ folder.
Usage: from bootstrap_ci import bootstrap_accuracy, precision_at_k
"""

import numpy as np
from typing import List, Dict


def bootstrap_accuracy(y_true: List[int], y_pred: List[int],
                        n_bootstrap: int = 1000,
                        confidence: float = 0.95) -> Dict:
    """
    Bootstrap confidence interval for classification accuracy.
    Makes the 98.3% figure statistically rigorous.

    Args:
        y_true:      Ground truth labels (0 or 1)
        y_pred:      Model predictions (0 or 1)
        n_bootstrap: Number of bootstrap resamples
        confidence:  CI level (0.95 = 95%)

    Returns dict with mean, std, ci_low, ci_high, all_scores
    """
    rng    = np.random.RandomState(42)
    n      = len(y_true)
    scores = []

    for _ in range(n_bootstrap):
        idx   = rng.randint(0, n, size=n)       # resample with replacement
        yt    = [y_true[i] for i in idx]
        yp    = [y_pred[i] for i in idx]
        acc   = sum(a == b for a, b in zip(yt, yp)) / n
        scores.append(acc)

    alpha  = (1 - confidence) / 2
    scores = np.array(scores)

    return {
        "mean":       float(np.mean(scores)),
        "std":        float(np.std(scores)),
        "ci_low":     float(np.percentile(scores, alpha * 100)),
        "ci_high":    float(np.percentile(scores, (1 - alpha) * 100)),
        "confidence": confidence,
        "n_bootstrap": n_bootstrap,
        "formatted":  (
            f"{np.mean(scores)*100:.1f}% "
            f"(95% CI: {np.percentile(scores,2.5)*100:.1f}%–"
            f"{np.percentile(scores,97.5)*100:.1f}%)"
        ),
        "all_scores": scores.tolist(),
    }


def precision_at_k(alerts_ranked: List[Dict],
                    ground_truth_ids: List[str],
                    k: int = 5) -> Dict:
    """
    Precision@K — of the top-K alerts fired, how many were genuine?
    More meaningful than raw precision for field officers who can
    only respond to a limited number of alerts at once.

    Args:
        alerts_ranked:    Alerts sorted by confidence/severity (highest first)
        ground_truth_ids: Elephant IDs that were genuinely near settlements
        k:                Number of top alerts to evaluate

    Returns dict with p@1, p@3, p@5, p@10
    """
    results = {}
    for ki in [1, 3, 5, 10]:
        if ki > len(alerts_ranked):
            continue
        top = alerts_ranked[:ki]
        hits = sum(
            1 for a in top
            if a.get("elephant_id", a.get("individual_id", "")) in ground_truth_ids
        )
        results[f"p_at_{ki}"] = round(hits / ki, 3)

    # Average precision (area under precision-recall curve)
    precisions = []
    hits_so_far = 0
    for i, alert in enumerate(alerts_ranked, 1):
        if alert.get("elephant_id", "") in ground_truth_ids:
            hits_so_far += 1
            precisions.append(hits_so_far / i)
    results["average_precision"] = round(
        float(np.mean(precisions)) if precisions else 0.0, 3
    )
    results["k_evaluated"] = min(k, len(alerts_ranked))
    return results


def compute_model_metrics(y_true: List[int],
                           y_pred: List[int],
                           y_prob: List[float] = None) -> Dict:
    """
    Full model evaluation: accuracy + CI + precision + recall + F1 + AUC.
    Drop-in replacement for simple accuracy reporting.
    """
    n  = len(y_true)
    tp = sum(1 for t, p in zip(y_true, y_pred) if t == 1 and p == 1)
    fp = sum(1 for t, p in zip(y_true, y_pred) if t == 0 and p == 1)
    tn = sum(1 for t, p in zip(y_true, y_pred) if t == 0 and p == 0)
    fn = sum(1 for t, p in zip(y_true, y_pred) if t == 1 and p == 0)

    acc   = (tp + tn) / n
    prec  = tp / (tp + fp) if (tp + fp) > 0 else 0.0
    rec   = tp / (tp + fn) if (tp + fn) > 0 else 0.0
    f1    = 2 * prec * rec / (prec + rec) if (prec + rec) > 0 else 0.0
    spec  = tn / (tn + fp) if (tn + fp) > 0 else 0.0

    result = {
        "accuracy":          round(acc,  4),
        "precision":         round(prec, 4),
        "recall":            round(rec,  4),
        "f1_score":          round(f1,   4),
        "specificity":       round(spec, 4),
        "true_positives":    tp,
        "false_positives":   fp,
        "true_negatives":    tn,
        "false_negatives":   fn,
        "n_samples":         n,
        "false_alarm_rate":  round(fp / n, 4),
        "miss_rate":         round(fn / n, 4),
    }

    # Bootstrap CI on accuracy
    ci = bootstrap_accuracy(y_true, y_pred)
    result["accuracy_ci_95"] = {
        "low":       round(ci["ci_low"],  4),
        "high":      round(ci["ci_high"], 4),
        "formatted": ci["formatted"],
    }

    # ROC-AUC if probabilities available
    if y_prob is not None:
        try:
            from sklearn.metrics import roc_auc_score
            result["roc_auc"] = round(float(roc_auc_score(y_true, y_prob)), 4)
        except Exception:
            pass

    return result